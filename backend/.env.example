# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=kipapi_ramani

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# Download link security
DOWNLOAD_TOKEN_EXPIRES_HOURS=48
DOWNLOAD_MAX_COUNT=3

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Payment Gateway (Selcom / Azam Pay / DPO)
PAYMENT_GATEWAY_URL=https://apigw.selcommobile.com/v1
PAYMENT_API_KEY=your_api_key
PAYMENT_API_SECRET=your_api_secret
PAYMENT_VENDOR_ID=your_vendor_id
PAYMENT_CALLBACK_URL=https://yourdomain.com/api/payments/webhook
